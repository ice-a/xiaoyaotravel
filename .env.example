# ===========================================
# 逍遥游 · 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ---------- 服务 ----------
PORT=3000

# ---------- 数据库（必需）----------
# Neon PostgreSQL 连接串（https://neon.tech）
# 也支持 DATABASE_URL / NEON_DATABASE_URL
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# ---------- AI 模型（必需）----------
# OpenAI 兼容接口配置
# 也支持 OPENAI_BASEURL / OPENAI_APIKEY / OPENAI_MODELNAME
baseurl=https://api.openai.com/v1
apikey=your_api_key_here
modelname=gpt-4o-mini

# ---------- 安全 ----------
# 删除攻略时的验证密码
DELETE_PASSWORD=your_password_here

# ---------- 用户认证 ----------
# 用户登录采用 username + key（API Key 模式），无需额外配置
# 首次登录自动注册账号，key 经过 SHA256 哈希存储
# 会话通过 X-User-Key / X-Username HTTP Header 传递

# ---------- 天气 ----------
# 使用 Open-Meteo 免费 API（无需 Key）
# 如需自定义 User-Agent 可取消注释：
# GEOCODE_USER_AGENT=xiaoyao-travel/1.0

# ---------- 地图（可选）----------
# 高德地图 Web Service，用于实时交通路线规划
# 申请地址：https://lbs.amap.com/
# AMAP_API_KEY=your_amap_key
# AMAP_WEB_KEY=your_amap_web_key

# ---------- 推广位（可选）----------
# 方式一：JSON 批量配置（推荐）
# PROMOTIONS_JSON=[{"id":"booking","title":"Booking.com","subtitle":"酒店预订","url":"https://booking.com","ctaText":"立即查看"}]

# 方式二：单独配置每个推广位
# BOOKING_PROMO_TITLE=Booking.com 酒店预订
# BOOKING_PROMO_DESC=全球海量酒店，低价保障
# BOOKING_PROMO_URL=https://www.booking.com
# BOOKING_PROMO_CTA=立即查看

# GETYOURGUIDE_PROMO_TITLE=GetYourGuide 景点玩乐
# GETYOURGUIDE_PROMO_DESC=发现当地热门体验和景点门票
# GETYOURGUIDE_PROMO_URL=https://www.getyourguide.com
# GETYOURGUIDE_PROMO_CTA=立即探索

# MEITUAN_PROMO_TITLE=美团美食
# MEITUAN_PROMO_DESC=本地美食优惠，外卖团购一应俱全
# MEITUAN_PROMO_URL=https://www.meituan.com
# MEITUAN_PROMO_CTA=查看美食

# DATACARD_PROMO_TITLE=境外流量卡
# DATACARD_PROMO_DESC=出国旅游必备，高速流量不限量
# DATACARD_PROMO_URL=https://example.com
# DATACARD_PROMO_CTA=了解详情
