PORT=3000

# Neon PostgreSQL (Vercel)
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: promotion cards shown in the UI
# Format: [{"title":"xx","desc":"","url":"https://..."}]
PROMOTIONS_JSON=[{"title":"酒店优惠","desc":"限时活动","url":"https://example.com/deal"}]

# Optional: Nominatim geocode user agent
GEOCODE_USER_AGENT=travel-guide-app/1.0

# OpenAI-compatible model config
baseurl=https://api.openai.com/v1
apikey=your_api_key
modelname=gpt-4o-mini

# Required for DELETE /api/guides/:id
DELETE_PASSWORD=your_delete_password
